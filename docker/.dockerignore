# Docker 构建时忽略的文件
# 这些文件不会被复制到镜像中

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 虚拟环境
venv/
env/
ENV/
demo/jupyter/.venv/
.venv/

# IDE 配置
.vscode/
.idea/
*.swp
*.swo

# Git
.git/
.gitignore

# 临时文件
*.log
*.tmp
.DS_Store

# Model weights (mount as volumes instead)
DeepAnalyze-8B/
DeepAnalyze-8B-MLX-FP16/
.cache/

# Runtime data (use volumes)
demo/chat/workspace/
demo/chat/projects/
demo/chat/deepanalyze.db
demo/chat/yutu_backups/
logs/

# Frontend build cache
demo/chat/frontend/node_modules/
demo/chat/frontend/.next/

# Large training/research directories
deepanalyze/ms-swift/
deepanalyze/SkyRL/
playground/

# 大文件
*.tar
*.tar.gz
*.zip
*.safetensors
*.bin

# 模型文件（通常很大，运行时再挂载）
models/
checkpoints/

