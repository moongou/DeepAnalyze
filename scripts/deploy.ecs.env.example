# Copy this file to scripts/deploy.ecs.env and adjust values for your ECS.
# scripts/deploy.ecs.env is ignored by git (*.env).

ECS_HOST=39.97.253.10
ECS_USER=root
ECS_SSH_PORT=22

# Deployment base directory on ECS.
REMOTE_BASE_DIR=/opt/deepanalyze
REMOTE_SERVICE_NAME=deepanalyze-api

# Service ports for this project.
REMOTE_API_PORT=8420
REMOTE_FILE_PORT=8421

# Model endpoint used by API.
REMOTE_MODEL_API_BASE=http://127.0.0.1:8000/v1

# Domain + port access policy.
# If your browser calls API directly from rainforgrain.top main site, keep both origins.
REMOTE_CORS_ALLOW_ORIGINS=https://rainforgrain.top,https://rainforgrain.top:8420

# If your ECS requires a custom SSH identity file, set this to absolute path.
# ECS_SSH_KEY_PATH=

# Optional runtime user/group for systemd service.
# REMOTE_RUN_USER=root
# REMOTE_RUN_GROUP=root
